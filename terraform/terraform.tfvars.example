# ==============================================================
# terraform.tfvars.example
# 이 파일을 복사하여 terraform.tfvars 로 저장 후 실제 값으로 교체하세요.
#   cp terraform/terraform.tfvars.example terraform/terraform.tfvars
# terraform.tfvars 는 .gitignore 처리됨 — 절대 커밋하지 마세요.
# ==============================================================

# ── 필수: 내 IP ───────────────────────────────────────────────
# 로컬 머신에서 Staging DB에 직접 접근하기 위한 SG 허용 IP
# 확인 방법: curl ifconfig.me
my_ip_cidr = "YOUR_IP/32"

# ── EventBridge 스케줄 토글 ────────────────────────────────────
# 기본 DISABLED — 의도치 않은 반복 실행 및 과금 방지
# 스케줄 검증 시 ENABLED로 변경 후, 완료 즉시 DISABLED 복원
eventbridge_rule_state = "DISABLED"   # 복제 Lambda (rate 5 minutes)
modify_data_rule_state = "DISABLED"   # 데이터 주입 Lambda (rate 1 minute, 시나리오 A용)

# ── Salesforce DC Outbound IP (선택) ───────────────────────────
# Phase B (DC 연동) 시작 전 공식 페이지에서 최신 IP 목록 확인 필수:
# https://help.salesforce.com/s/articleView?id=data.c360_a_data_cloud_ip_address_allowlist.htm
# 기본값(variables.tf)의 CAN 리전 IP 또는 아래 형식으로 직접 지정:
# dc_kor6_outbound_ips = [
#   "X.X.X.X/32",
#   "X.X.X.X/32",
# ]
